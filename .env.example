NODE_ENV=production

# MongoDB root credentials used by the mongo container on first startup.
MONGO_ROOT_USER=
MONGO_ROOT_PASS=

# JWT/session secrets should be long random strings, ideally 64+ characters.
JWT_SECRET=
SESSION_SECRET=

# Google OAuth credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Browser-facing URLs for the HTTPS backend and frontend.
SERVER_URL=https://localhost:5000
CLIENT_URL=https://localhost:3000

# Browser bundle API URL used by the Next.js frontend.
NEXT_PUBLIC_API_URL=https://localhost:5000/api

# Email credentials for OTP and password reset delivery.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@quill.app

# OTP expiry window in minutes.
OTP_EXPIRY_MINUTES=10
